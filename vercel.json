{
    "redirects": [
        {
            "source": "/audit",
            "destination": "https://copyboost.io/audit-expert",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/_astro/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/_next/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}