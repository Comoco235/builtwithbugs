---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

function tagToSlug(tag: string): string {
  return tag.toLowerCase().replace(/\s+/g, '-');
}

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const siteUrl = Astro.site?.toString() || 'https://www.builtwithbugs.com/';
const collectionSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Blog — ${SITE_TITLE}`,
  description: SITE_DESCRIPTION,
  url: `${siteUrl}blog/`,
  isPartOf: { "@id": `${siteUrl}#website` },
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}blog/` },
    ],
  },
});

function getReadingTime(content: string) {
  const wordsPerMinute = 200;
  const noOfWords = content.split(/\s+/g).length;
  const minutes = noOfWords / wordsPerMinute;
  return Math.ceil(minutes);
}
---

<MainLayout title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
    <script is:inline type="application/ld+json" set:html={collectionSchema} />
    <div class="section-header">
        <h1>Blog - Built With Bugs</h1>
        <span class="section-label">// TOUS LES ARTICLES</span>
    </div>
    <ul class="post-grid">
        {posts.map((post) => {
            const readTime = post.data.readingTime || (post.body ? `${getReadingTime(post.body)} min de lecture` : null);
            
            return (
            <li>
                <article>
                    <a href={`/blog/${post.id}/`} class="post-card">
                        <div class="post-content">
                            <div class="post-date">
                                <FormattedDate date={post.data.pubDate} />
                                {readTime && <span> • {readTime}</span>}
                            </div>
                            <h3 class="post-title">{post.data.title}</h3>
                            <p class="post-desc">{post.data.description}</p>
                            <span class="post-cta">Lire l'article →</span>
                        </div>
                    </a>
                    {post.data.tags && post.data.tags.length > 0 && (
                        <div class="post-tags">
                            {post.data.tags.map(tag => (
                                <a href={`/blog/tag/${tagToSlug(tag)}/`} class="tag-badge">{tag}</a>
                            ))}
                        </div>
                    )}
                </article>
            </li>
        )})}
    </ul>

    <style>
      h1 {
        margin-bottom: 0.5rem;
        font-size: clamp(2rem, 5vw, 3rem);
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .section-label {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.1em;
        display: block;
        margin-bottom: 2rem;
      }

      .post-grid {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .post-card {
        display: flex;
        flex-direction: column;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        transition: all 0.3s ease;
      }

      .post-card:hover {
        border-color: var(--accent);
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
        transform: translateY(-4px);
        text-decoration: none;
      }

      .post-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .post-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text3);
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .post-title {
        font-family: var(--display);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        line-height: 1.3;
      }

      .post-desc {
        font-size: 14px;
        color: var(--text2);
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 0.5rem;
      }

      .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem 1rem;
        margin-top: -0.25rem;
      }

      .tag-badge {
        font-family: var(--mono);
        font-size: 10px;
        background: var(--border);
        color: var(--text2);
        padding: 2px 8px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        transition: all 0.2s;
      }

      .tag-badge:hover {
        background: rgba(0, 212, 255, 0.1);
        color: var(--accent);
      }

      .post-cta {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.05em;
        margin-top: auto;
      }
    </style>
</MainLayout>