---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

function tagToSlug(tag: string): string {
  return tag.toLowerCase().replace(/\s+/g, '-');
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  const tagMap = new Map<string, { label: string; posts: CollectionEntry<'blog'>[] }>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const slug = tagToSlug(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { label: tag, posts: [] });
      }
      const entry = tagMap.get(slug)!;
      if (!entry.posts.find(p => p.id === post.id)) {
        entry.posts.push(post);
      }
    }
  }

  return [...tagMap.entries()].map(([slug, { label, posts: tagPosts }]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: tagPosts.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
      ),
    },
  }));
}

type Props = { label: string; posts: CollectionEntry<'blog'>[] };

const { label, posts } = Astro.props;
const { tag } = Astro.params;

const siteUrl = Astro.site?.toString() || 'https://www.builtwithbugs.com/';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const collectionSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Articles sur ${label} — Built With Bugs`,
  description: `Tous les articles Built With Bugs sur le thème "${label}" : automatisation IA, Python, VPS et build in public.`,
  url: pageUrl,
  isPartOf: { '@id': `${siteUrl}#website` },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}blog/` },
      { '@type': 'ListItem', position: 3, name: label, item: pageUrl },
    ],
  },
});
---

<MainLayout
  title={`${label} — Built With Bugs`}
  description={`${posts.length} article${posts.length > 1 ? 's' : ''} sur "${label}" : automatisation IA, Python, VPS et build in public.`}
>
  <script is:inline type="application/ld+json" set:html={collectionSchema} />

  <div class="section-header">
    <a href="/blog" class="back-link">← Tous les articles</a>
    <h1>#{label}</h1>
    <span class="count">{posts.length} article{posts.length > 1 ? 's' : ''}</span>
  </div>

  <ul class="post-grid">
    {posts.map((post) => (
      <li>
        <article>
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-content">
              <div class="post-date">
                <FormattedDate date={post.data.pubDate} />
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map(t => (
                    <a
                      href={`/blog/tag/${tagToSlug(t)}/`}
                      class={`tag-badge${tagToSlug(t) === tag ? ' active' : ''}`}
                    >
                      {t}
                    </a>
                  ))}
                </div>
              )}
              <span class="post-cta">Lire l'article →</span>
            </div>
          </a>
        </article>
      </li>
    ))}
  </ul>

  <style>
    .section-header {
      margin-bottom: 2rem;
    }

    .back-link {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text3);
      text-decoration: none;
      display: inline-block;
      margin-bottom: 1rem;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--accent);
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.25rem;
    }

    .count {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text3);
      letter-spacing: 0.05em;
    }

    .post-grid {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .post-card {
      display: flex;
      flex-direction: column;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .post-card:hover {
      border-color: var(--accent);
      transform: translateY(-4px);
      text-decoration: none;
    }

    .post-content {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-date {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      letter-spacing: 0.05em;
    }

    .post-title {
      font-family: var(--display);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.02em;
      line-height: 1.3;
    }

    .post-desc {
      font-size: 14px;
      color: var(--text2);
      font-weight: 300;
      line-height: 1.6;
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .tag-badge {
      font-family: var(--mono);
      font-size: 10px;
      background: var(--border);
      color: var(--text2);
      padding: 2px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-decoration: none;
      transition: all 0.2s;
    }

    .tag-badge:hover,
    .tag-badge.active {
      background: rgba(0, 212, 255, 0.1);
      color: var(--accent);
      border: 1px solid rgba(0, 212, 255, 0.3);
    }

    .post-cta {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--accent);
      letter-spacing: 0.05em;
      margin-top: auto;
    }
  </style>
</MainLayout>
