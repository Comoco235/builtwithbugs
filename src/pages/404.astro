---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead
      title="404 — Page introuvable · Built With Bugs"
      description="Cette page n'existe pas ou a été déplacée. Retrouve tous les articles du blog sur l'automatisation IA, Python et le build in public."
    />
  </head>
  <body>
    <Header />
    <main>
      <div class="error-block">
        <span class="error-code">404</span>
        <h1>Page introuvable</h1>
        <p>Cette URL n'existe pas ou a été déplacée.</p>
        <div class="actions">
          <a href="/" class="btn-primary">← Accueil</a>
          <a href="/blog" class="btn-secondary">Tous les articles</a>
        </div>
      </div>

      {posts.length > 0 && (
        <div class="recent">
          <p class="recent-label">// DERNIERS ARTICLES</p>
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </main>
    <Footer />

    <style>
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 6rem 2rem;
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4rem;
      }

      .error-block {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      .error-code {
        font-family: var(--mono);
        font-size: clamp(4rem, 15vw, 8rem);
        font-weight: 700;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
      }

      h1 {
        font-family: var(--display);
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        color: var(--text);
        margin: 0;
      }

      p {
        color: var(--text2);
        font-size: 1rem;
        margin: 0;
      }

      .actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .btn-primary,
      .btn-secondary {
        font-family: var(--mono);
        font-size: 13px;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-primary:hover {
        opacity: 0.85;
        text-decoration: none;
      }

      .btn-secondary {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text2);
      }

      .btn-secondary:hover {
        border-color: var(--accent);
        color: var(--accent);
        text-decoration: none;
      }

      .recent {
        width: 100%;
        max-width: 500px;
        text-align: center;
      }

      .recent-label {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--accent);
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
      }

      .recent ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .recent a {
        font-size: 14px;
        color: var(--text2);
        text-decoration: none;
        transition: color 0.2s;
      }

      .recent a:hover {
        color: var(--accent);
      }
    </style>
  </body>
</html>
