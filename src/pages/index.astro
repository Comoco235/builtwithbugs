---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE_TITLE,
  "url": Astro.site,
  "description": SITE_DESCRIPTION,
  "author": {
    "@type": "Person",
    "name": "Samwane"
  }
});
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script is:inline type="application/ld+json" set:html={websiteSchema} />
  </head>
  <body>
    <nav>
      <a href="/" class="logo">built<span>with</span>bugs<span>.com</span></a>
      <div class="nav-links">
  <a href="/">Home</a>
  <a href="/blog">Blog</a>
  <a href="/about">About</a>
  <a href="/audit">Audit</a>
</div>
    </nav>

    <header class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid"></div>
      <div class="hero-content">
        <div class="hero-badge">● BUILD IN PUBLIC</div>
        <h1>
          Hacker sa visibilité<br>
          <span class="gradient">avec la tech et l'IA</span>
        </h1>
        <p class="hero-sub">
          Dev, marketing digital et automatisation, construits en public | bugs inclus.
          Chaque article est un projet réel, chaque erreur est du contenu.
        </p>
        <div class="hero-tags">
          <span class="tag">🐍 Python</span>
          <span class="tag">🤖 IA & LLM</span>
          <span class="tag">📈 Marketing</span>
          <span class="tag">🖥️ VPS & Dev</span>
        </div>
      </div>
    </header>

    <main>
      <div class="section-header">
        <span class="section-label">// AUDIT COPY</span>
      </div>
      <div class="audit-teaser">
        <div class="badge-row">
          <span class="badge">● Audit Copy</span>
          <span class="badge gray">97€ · 72h</span>
        </div>
        <h2 class="audit-title">Tes ventes stagnent.<br/><em>Ton produit n'est probablement pas le problème.</em></h2>
        <p class="audit-desc">En 72h, je diagnostique ce qui bloque dans ta copy (fiches, hooks, emails) et je te montre quoi corriger pour relancer tes conversions.</p>
        <a href="/audit" class="cta-btn">→ Découvrir l'audit</a>
      </div>

      <div class="section-header" style="margin-top: 4rem;">
        <span class="section-label">// DERNIERS ARTICLES</span>
      </div>
      <ul class="post-grid">
        {posts.map((post) => (
          <li>
            <article>
              <a href={`/blog/${post.id.replace('.md', '')}/`} class="post-card">
                <div class="post-content">
                  <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-desc">{post.data.description}</p>
                  <span class="post-cta">Lire l'article →</span>
                </div>
              </a>
            </article>
          </li>
        ))}
      </ul>
    </main>

    <footer>
  <span>builtwithbugs.com</span> · Hacker sa visibilité avec la tech et l'IA
  <div class="footer-links">
    <a href="https://www.linkedin.com/in/samwane-abdallah-837844119" target="_blank">LinkedIn</a>
    <a href="https://www.reddit.com/user/samwane/" target="_blank">Reddit</a>
    <a href="https://x.com/samwanebuild/" target="_blank">X (Twitter)</a>
    <a href="https://www.instagram.com/copyboost25/" target="_blank">Instagram</a>
  </div>
</footer>

    <style>
      nav {
        background: rgba(255,255,255,0.9);
        border-bottom: 1px solid var(--border);
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      nav a.logo {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
      }

      nav a.logo span { color: var(--text3); }

      nav .nav-links {
        display: flex;
        gap: 1.5rem;
      }

      nav .nav-links a {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text3);
        text-decoration: none;
        transition: color 0.2s;
      }

      nav .nav-links a:hover { color: var(--accent); }

      .hero {
        position: relative;
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6rem 2rem 4rem;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 60% at 60% 20%, rgba(0,212,255,0.07) 0%, transparent 60%),
          radial-gradient(ellipse 50% 40% at 10% 80%, rgba(124,58,237,0.08) 0%, transparent 50%);
      }

      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: linear-gradient(180deg, transparent, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.5) 70%, transparent);
      }

      .hero-content {
        position: relative;
        max-width: 860px;
        margin: 0 auto;
        width: 100%;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,212,255,0.08);
        border: 1px solid rgba(0,212,255,0.2);
        border-radius: 100px;
        padding: 6px 16px;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        margin-bottom: 2rem;
        letter-spacing: 0.05em;
      }

      .hero h1 {
        font-family: var(--display);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
      }

      .gradient {
        background: linear-gradient(135deg, var(--accent) 0%, #60a5fa 50%, var(--accent2) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-sub {
        font-size: 1.15rem;
        color: var(--text2);
        max-width: 600px;
        line-height: 1.7;
        margin-bottom: 2rem;
        font-weight: 300;
      }

      .hero-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .tag {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        color: var(--text2);
        font-family: var(--mono);
      }

      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }

      .audit-teaser {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
      }
      .badge-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
      .badge { display: inline-flex; align-items: center; background: rgba(0,136,204,0.08); border: 1px solid rgba(0,136,204,0.2); border-radius: 100px; padding: 5px 14px; font-family: var(--mono); font-size: 12px; color: var(--accent); }
      .badge.gray { background: rgba(108,117,125,0.1); border-color: rgba(108,117,125,0.3); color: var(--text3); }
      .audit-title { font-family: var(--display); font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1rem; background: linear-gradient(135deg, var(--text) 0%, var(--text2) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .audit-title em { font-style: normal; background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .audit-desc { font-size: 1rem; color: var(--text2); font-weight: 300; margin-bottom: 1.5rem; line-height: 1.6; }
      .cta-btn { display: inline-block; background: var(--accent); color: #fff; font-family: var(--mono); font-size: 14px; font-weight: 700; padding: 0.85rem 1.75rem; border-radius: 8px; text-decoration: none; transition: opacity 0.2s, transform 0.15s; }
      .cta-btn:hover { opacity: 0.88; transform: translateY(-2px); text-decoration: none; }

      .section-label {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.1em;
        display: block;
        margin-bottom: 2rem;
      }

      .post-grid {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .post-card {
  display: flex;
  flex-direction: column;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  transition: border-color 0.2s, transform 0.2s;
}

      .post-card:hover {
        border-color: rgba(0,212,255,0.3);
        transform: translateY(-2px);
        text-decoration: none;
      }

      .post-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .post-content {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

      .post-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text3);
        letter-spacing: 0.05em;
      }

      .post-title {
        font-family: var(--display);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        line-height: 1.3;
      }

      .post-desc {
        font-size: 14px;
        color: var(--text2);
        font-weight: 300;
        line-height: 1.6;
        flex: 1;
      }

      .post-cta {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.05em;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 2rem;
        text-align: center;
        color: var(--text3);
        font-size: 13px;
        font-family: var(--mono);
      }

      footer span { color: var(--accent); }

      @media (max-width: 600px) {
        .post-card { grid-template-columns: 1fr; }
        .post-img { height: 180px; }
        .post-content { padding: 1rem; }
      }
    </style>
  </body>
</html>