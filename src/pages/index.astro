---
import BaseHead from '../components/BaseHead.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_TITLE = 'BuiltWithBugs — Automatisation IA, Build in Public & Python';
const PAGE_DESC  = 'Automatisation IA, build in public et Python pour indie makers francophones. VPS Hetzner, prompt engineering, marketing digital — chaque bug est une leçon.';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://www.builtwithbugs.com';

const homeSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": `${siteUrl}/`,
      "name": "Built With Bugs",
      "description": "Automatisation IA, build in public et Python pour indie makers francophones.",
      "inLanguage": "fr-FR",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/blog?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Samwane ABDALLAH",
      "url": `${siteUrl}/`,
      "jobTitle": "Indie Hacker & D\u00e9veloppeur",
      "sameAs": [
        "https://x.com/samwanebuild",
        "https://www.linkedin.com/in/samwane-abdallah-837844119"
      ]
    },
    {
      "@type": "ItemList",
      "name": "Derniers articles \u2014 Built With Bugs",
      "url": `${siteUrl}/`,
      "itemListElement": posts.map((post, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "url": `${siteUrl}/blog/${post.id}/`
      }))
    }
  ]
});
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESC} />
    <script is:inline type="application/ld+json" set:html={homeSchema} />
  </head>
  <body>
    <Header />

    <header class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid"></div>
      <div class="hero-content">
        <div class="hero-badge">● BUILD IN PUBLIC</div>
        <h1 aria-label="Hacker sa visibilité avec la tech et l'IA — automatisation IA, build in public et Python pour makers francophones">
          Hacker sa visibilité<br>
          <span class="gradient">avec la tech et l'IA</span>
        </h1>
        <p class="hero-sub">
          Automatisation IA, Python et marketing digital construits en public —
          chaque projet est un article, chaque bug est une leçon.
        </p>
        <div class="hero-tags">
          <a href="/blog/tag/python/" class="tag">🐍 Python</a>
          <a href="/blog/tag/ia/" class="tag">🤖 IA & LLM</a>
          <a href="/blog/tag/marketing/" class="tag">📈 Marketing</a>
          <a href="/blog/tag/vps/" class="tag">🖥️ VPS & Dev</a>
        </div>
      </div>
    </header>

    <main>
      <div class="section-header" style="margin-top: 4rem;">
        <h2 class="section-h2">Derniers articles sur l'automatisation et le build in public</h2>
        <span class="section-label">// DERNIERS ARTICLES</span>
      </div>
      <ul class="post-grid">
        {posts.map((post, index) => (
          <li>
            <article>
              <a href={`/blog/${post.id}/`} class="post-card" data-astro-prefetch="viewport">
                {post.data.heroImage && (
                  <div class="post-image">
                    <Image 
                      src={post.data.heroImage} 
                      alt={post.data.heroImageAlt || post.data.title} 
                      width={400} 
                      height={225}
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      decoding="async"
                      class="post-img"
                    />
                  </div>
                )}
                <div class="post-content">
                  <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-desc">{post.data.description}</p>
                  <span class="post-cta">Lire l'article →</span>
                </div>
              </a>
            </article>
          </li>
        ))}
      </ul>
    </main>

    <Footer />
    <BackToTop />

    <style>

      .hero {
        position: relative;
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6rem 2rem 4rem;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 60% at 60% 20%, rgba(0,212,255,0.07) 0%, transparent 60%),
          radial-gradient(ellipse 50% 40% at 10% 80%, rgba(124,58,237,0.08) 0%, transparent 50%);
      }

      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: linear-gradient(180deg, transparent, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.5) 70%, transparent);
      }

      .hero-content {
        position: relative;
        max-width: 860px;
        margin: 0 auto;
        width: 100%;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,212,255,0.08);
        border: 1px solid rgba(0,212,255,0.2);
        border-radius: 100px;
        padding: 6px 16px;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        margin-bottom: 2rem;
        letter-spacing: 0.05em;
      }

      .hero h1 {
        font-family: var(--display);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
      }

      .gradient {
        background: linear-gradient(135deg, var(--accent) 0%, #60a5fa 50%, var(--accent2) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-sub {
        font-size: 1.15rem;
        color: var(--text2);
        max-width: 600px;
        line-height: 1.7;
        margin-bottom: 2rem;
        font-weight: 300;
      }

      .hero-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .tag {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        color: var(--text2);
        font-family: var(--mono);
        text-decoration: none;
      }

      .tag:hover {
        border-color: rgba(0,212,255,0.3);
        color: var(--accent);
      }

      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }

      .section-h2 {
        font-family: var(--display);
        font-size: 1rem;
        font-weight: 400;
        color: var(--text3);
        letter-spacing: -0.01em;
        margin-bottom: 0.25rem;
      }

      .section-label {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.1em;
        display: block;
        margin-bottom: 2rem;
      }

      .post-grid {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .post-card {
        display: grid;
        grid-template-columns: 380px 1fr;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      }

      .post-card:hover {
        border-color: var(--accent);
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        text-decoration: none;
      }

      .post-image {
        width: 100%;
        height: 100%;
        overflow: hidden;
        border-right: 1px solid var(--border);
        background: #ffffff;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .post-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 12px;
        transition: transform 0.3s ease;
      }

      .post-card:hover .post-img {
        transform: scale(1.05);
      }

      .post-content {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.75rem;
        flex: 1;
      }

      .post-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text3);
        letter-spacing: 0.05em;
      }

      .post-title {
        font-family: var(--display);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      .post-desc {
        font-size: 14px;
        color: var(--text2);
        font-weight: 300;
        line-height: 1.6;
        flex: 1;
      }

      .post-cta {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--accent);
        letter-spacing: 0.05em;
      }

      @media (max-width: 768px) {
        .post-card { 
          grid-template-columns: 1fr; 
        }
        .post-image {
          border-right: none;
          border-bottom: 1px solid var(--border);
          height: 200px;
        }
        .post-content { padding: 1.25rem; }
      }
    </style>
  </body>
</html>
