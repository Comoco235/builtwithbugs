---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": heroImage ? new URL(heroImage.src, Astro.url.origin).toString() : undefined,
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": "Samwane ABDALLAH",
    "url": "https://builtwithbugs.com"
  }
};
---

<html lang="fr">
	<head>
		<BaseHead title={title} description={description} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />
		<style>
			main {
				max-width: 860px;
				margin: 0 auto;
				padding: 4rem 2rem 6rem;
			}
			.prose {
				max-width: 100%;
				margin: auto;
				color: var(--text);
			}
			.title {
				margin-bottom: 3rem;
				text-align: left;
			}
			.title h1 {
				margin: 0 0 1rem 0;
                font-size: clamp(1.8rem, 5vw, 2.8rem);
                line-height: 1.15;
                font-weight: 800;
                background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
			}
			.date {
				font-family: var(--mono);
				font-size: 13px;
				color: var(--text3);
                letter-spacing: 0.05em;
			}
			.last-updated-on {
				font-style: italic;
                margin-top: 0.5rem;
			}
            
            @media (max-width: 600px) {
                main {
                    padding: 2rem 1rem 4rem;
                }
            }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header>
                    <div class="title">
                        <h1>{title}</h1>
                        <div class="date">
                            Publié le {pubDate.toLocaleDateString('fr-fr', { year: 'numeric', month: 'long', day: 'numeric' })}
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        Dernière mise à jour le {updatedDate.toLocaleDateString('fr-fr', { year: 'numeric', month: 'long', day: 'numeric' })}
                                    </div>
                                )
                            }
                        </div>
                    </div>
				</header>
                <div class="prose">
                    <slot />
                </div>
			</article>
		</main>
		<Footer />
		<BackToTop />
	</body>
</html>

<style is:global>
  article img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2.5rem auto;
    border-radius: 16px;
    border: 1px solid var(--border);
  }
  
  .prose h2 {
    margin: 3rem 0 1.5rem;
    font-size: 1.75rem;
  }
  
  .prose p {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    line-height: 1.7;
  }
</style>
