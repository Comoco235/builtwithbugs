---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title: string;
    description: string;
  };
}

const { frontmatter } = Astro.props;
const title = frontmatter?.title || Astro.props.title || SITE_TITLE;
const description = frontmatter?.description || Astro.props.description || SITE_DESCRIPTION;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <BackToTop />

    <style>
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
        min-height: 70vh;
      }

      @media (max-width: 600px) {
        main {
          padding: 2rem 1rem 4rem;
        }
      }
    </style>
  </body>
</html>
